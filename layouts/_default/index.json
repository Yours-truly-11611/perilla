{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
  {{- $summary := printf "%s %s" (.Description | default "") (.Summary | plainify) | strings.TrimLeft " " -}}
  {{- $.Scratch.Add "index" (dict "title" .Title "summary" $summary "permalink" .Permalink "date" (.Date.Format "2006-01-02")) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
